---
import LegalLayout from "../layouts/LegalLayout.astro";

const sections = [
  { id: "about", label: "About Canopryx" },
  { id: "scope", label: "Scope" },
  { id: "product-status", label: "Product status" },
  { id: "no-credential-storage", label: "No credential storage" },
  { id: "acceptable-use", label: "Acceptable use" },
  { id: "security-research", label: "Security research" },
  { id: "intellectual-property", label: "Intellectual property" },
  { id: "feedback", label: "Feedback" },
  { id: "design-partners", label: "Design partners" },
  { id: "third-party-links", label: "Third-party links" },
  { id: "security-statements", label: "Security statements" },
  { id: "no-advice", label: "No professional advice" },
  { id: "disclaimers", label: "Disclaimers" },
  { id: "liability", label: "Limitation of liability" },
  { id: "indemnity", label: "Indemnity" },
  { id: "restriction", label: "Suspension or restriction" },
  { id: "website-changes", label: "Website changes" },
  { id: "terms-changes", label: "Changes to these terms" },
  { id: "governing-law", label: "Governing law" },
  { id: "contact", label: "Contact" },
