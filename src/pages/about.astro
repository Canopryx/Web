---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFrame from "../components/SiteFrame.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ValueCard from "../components/ValueCard.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import RadarEffect from "../components/RadarEffect.astro";

const values = [
  {
    title: "Focused",
    description: "We build focused security products with a cleaner public surface.",
  },
  {
    title: "Deliberate",
    description: "What is public is intentional. What is not ready stays private.",
  },
  {
    title: "Practical",
    description: "The goal is clarity, not noise.",
  },
];
---

<BaseLayout
  title="About - Canopryx"
  description="Learn about Canopryx — building modern cybersecurity tools with a cleaner and more deliberate public presence."
>
  <SiteFrame>
    <main>
      <section class="about page-shell">
        <div class="about__header">

          <h1 class="about__title enter-after-nav" style="--enter-delay: 0.5s;">About Canopryx</h1>
          <p class="about__subtitle enter-after-nav" style="--enter-delay: 0.58s;">
            Building modern cybersecurity tools with a cleaner and more deliberate public&nbsp;presence.
          </p>
        </div>

        <div class="about__grid" id="principles">
          {values.map((value, i) => (
            <ValueCard
              title={value.title}
              description={value.description}
              index={i}
            />
          ))}
        </div>

        <RadarEffect />
      </section>
    </main>
  </SiteFrame>

  <SiteFooter noMargin={true} />
  <ScrollReveal />
</BaseLayout>
