---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFrame from "../components/SiteFrame.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout
  title="Request Early Access - Canopryx"
  description="Tell us about your security environment and request early access to Canopryx."
>
  <SiteFrame>
    <main class="access page-shell">
      <header class="access__intro enter-after-nav" style="--enter-delay: 0.45s;">
        <h1>Request early access.</h1>
        <p class="access__lede">We’re opening Canopryx to a small number of teams responsible for sensitive infrastructure. Tell us how you work today and where you need more control.</p>
        
        <nav class="progress-rail" aria-label="Form progress" id="progress-rail">
          <div class="progress-rail__mobile-status" aria-hidden="true">Step <span id="mobile-step">1</span> of 3</div>
          <ul class="progress-rail__list">
            <li>
              <a href="#step-details" class="progress-rail__link is-active" aria-current="step" data-step="step-details">
                <span class="progress-rail__marker">1</span>
                <span class="progress-rail__label">Your details</span>
              </a>
            </li>
            <li>
              <a href="#step-environment" class="progress-rail__link" data-step="step-environment">
                <span class="progress-rail__marker">2</span>
                <span class="progress-rail__label">Environment</span>
              </a>
            </li>
            <li>
              <a href="#step-priorities" class="progress-rail__link" data-step="step-priorities">
                <span class="progress-rail__marker">3</span>
                <span class="progress-rail__label">Priorities</span>
              </a>
            </li>
          </ul>
        </nav>

        <div class="access__aside" aria-label="Application process">
          <div><strong>We read every request.</strong><p>There is no automated qualification or mailing list.</p></div>
          <div><strong>If there’s a fit, we’ll write back.</strong><p>You’ll hear directly from the team building Canopryx.</p></div>
        </div>
      </header>

      <section class="access__panel enter-after-nav" style="--enter-delay: 0.62s;" aria-labelledby="application-title">
        <div class="access__panel-heading">
          <h2 id="application-title">Tell us about your team</h2>
          <p>A few details help us understand your environment before we get in touch.</p>
        </div>

        <form id="early-access-form" class="access-form" novalidate>
          <input type="hidden" name="formType" value="early-access" />
          
          <fieldset id="step-details" class="access-form__step">
            <legend class="sr-only">Your details</legend>
            <div class="access-form__row">
              <div class="form-field">
                <label for="name">Name</label>
                <input id="name" name="name" type="text" autocomplete="name" maxlength="100" required placeholder="Your full name" />
              </div>
              <div class="form-field">
                <label for="email">Work email</label>
                <input id="email" name="email" type="email" autocomplete="email" maxlength="100" required placeholder="you@company.com" />
              </div>
            </div>

            <div class="access-form__row">
              <div class="form-field">
                <label for="organization">Organization</label>
                <input id="organization" name="organization" type="text" autocomplete="organization" maxlength="150" required placeholder="Organization name" />
              </div>
              <div class="form-field">
                <label for="role">Role / title</label>
                <input id="role" name="role" type="text" autocomplete="organization-title" maxlength="120" required placeholder="e.g. Head of Security" />
              </div>
            </div>

            <div class="access-form__row">
              <div class="form-field">
                <label for="industry">Industry</label>
                <select id="industry" name="industry" required>
                  <option value="" selected disabled>Select industry</option>
                  <option>Defense</option><option>Fintech</option><option>Healthcare</option>
                  <option>Government</option><option>Critical infrastructure</option>
                  <option>Enterprise technology</option><option>Other</option>
                </select>
              </div>
              <div class="form-field">
                <label for="companySize">Team / company size</label>
                <select id="companySize" name="companySize" required>
                  <option value="" selected disabled>Select size</option>
                  <option>1-10</option><option>11-50</option><option>51-200</option>
                  <option>201-500</option><option>501-1,000</option><option>1,001+</option>
                </select>
              </div>
            </div>
          </fieldset>

          <fieldset id="step-environment" class="access-form__step">
            <legend class="sr-only">Environment</legend>
            <div class="form-field">
              <label for="secretsSetup">Current secrets management setup</label>
              <select id="secretsSetup" name="secretsSetup" required>
                <option value="" selected disabled>Select current setup</option>
                <option>None / manual processes</option><option>Environment files</option>
                <option>Cloud-provider secrets service</option><option>Third-party SaaS</option>
                <option>Self-hosted solution</option><option>Mixed environment</option><option>Other</option>
              </select>
            </div>
          </fieldset>

          <fieldset id="step-priorities" class="access-form__step">
            <legend class="sr-only">Priorities</legend>
            <div class="form-field">
              <label for="protectionGoals">What are you trying to protect?</label>
              <textarea id="protectionGoals" name="protectionGoals" rows="4" maxlength="2000" required placeholder="Systems, credentials, operational data, deployment constraints..."></textarea>
            </div>

            <div class="form-field">
              <label for="message">Additional message <span>Optional</span></label>
              <textarea id="message" name="message" rows="3" maxlength="2000" placeholder="Anything else that would help us understand the fit?"></textarea>
            </div>
          </fieldset>

          <div hidden inert aria-hidden="true"><label for="website">Website</label><input id="website" name="website" type="text" tabindex="-1" autocomplete="off" /></div>

          <button class="access-form__submit btn-primary" id="submit-btn" type="submit">
            <span id="btn-text">Submit request</span>
            <svg id="btn-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            <span id="btn-spinner" class="spinner" hidden aria-hidden="true"></span>
          </button>
          <div id="form-status" class="form-status" role="status" aria-live="polite" hidden></div>
        </form>
      </section>
    </main>
  </SiteFrame>
  <SiteFooter />
</BaseLayout>

<style>
  .access { display: grid; grid-template-columns: minmax(0, 0.82fr) minmax(34rem, 1.18fr); gap: clamp(3rem, 7vw, 7rem); align-items: start; padding-block: 11rem 6rem; }
  .access__intro { position: sticky; top: 8rem; padding-top: 1.25rem; }
  .access__intro h1 { max-width: 8ch; font-size: clamp(2.8rem, 5vw, 4.8rem); line-height: 0.98; letter-spacing: -0.055em; font-weight: 580; }
  .access__lede { margin-top: 1.5rem; max-width: 32rem; font-size: 1.05rem; line-height: 1.85; color: var(--color-text-muted); }
  
  /* Progress Rail */
  .progress-rail { margin-top: 2.5rem; position: relative; }
  .progress-rail__mobile-status { display: none; font-size: 0.85rem; font-weight: 600; color: var(--color-primary); letter-spacing: 0.1em; text-transform: uppercase; }
  .progress-rail__list { position: relative; display: flex; flex-direction: column; gap: 1.5rem; }
  .progress-rail__list::before { content: ''; position: absolute; left: 13px; top: 10px; bottom: 10px; width: 2px; background: rgba(39, 49, 58, 0.08); z-index: 0; }
  
  .progress-rail__link { position: relative; z-index: 1; display: flex; align-items: center; gap: 1rem; color: var(--color-text-muted); text-decoration: none; transition: color 0.2s; }
  .progress-rail__link:hover { color: var(--color-text); }
  .progress-rail__marker { display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; border-radius: 50%; font-size: 0.75rem; font-weight: 700; background: var(--color-page); border: 2px solid rgba(39, 49, 58, 0.15); color: var(--color-text-muted); transition: background 0.2s, border-color 0.2s, color 0.2s; }
  .progress-rail__label { font-size: 0.95rem; font-weight: 600; }
  
  .progress-rail__link.is-active { color: var(--color-text); }
  .progress-rail__link.is-active .progress-rail__marker { background: var(--color-primary); border-color: var(--color-primary); color: white; box-shadow: 0 0 0 4px rgba(42, 111, 126, 0.15); }

  .access__aside { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
  .access__aside strong { font: 650 0.95rem/1.3 var(--font-display); color: var(--color-text); }
  .access__aside p { margin-top: 0.45rem; font-size: 0.83rem; line-height: 1.6; color: var(--color-text-muted); }
  .access__panel { padding: clamp(1.5rem, 4vw, 3rem); background: rgba(255,255,255,0.77); border: 1px solid rgba(255,255,255,0.9); border-radius: 28px; box-shadow: 0 28px 70px rgba(39,49,58,0.1); backdrop-filter: blur(18px); }
  .access__panel-heading { padding-bottom: 1.8rem; border-bottom: 1px solid var(--color-border); }
  .access__panel-heading h2 { font-size: clamp(1.65rem, 3vw, 2.25rem); letter-spacing: -0.035em; }
  .access__panel-heading p { max-width: 30rem; margin-top: 0.65rem; font-size: 0.9rem; line-height: 1.65; color: var(--color-text-muted); }
  
  .access-form { display: flex; flex-direction: column; gap: 2.5rem; padding-top: 1.8rem; }
  .access-form__step { display: flex; flex-direction: column; gap: 1.25rem; border: none; padding: 0; margin: 0; scroll-margin-top: 10rem; }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
  
  .access-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .form-field { display: flex; flex-direction: column; gap: 0.55rem; }
  .form-field label { font: 650 0.8rem/1.2 var(--font-display); letter-spacing: 0.015em; color: var(--color-text); }
  .form-field label span { margin-left: 0.35rem; font-weight: 450; color: var(--color-text-muted); }
  .form-field input, .form-field select, .form-field textarea { width: 100%; padding: 0.9rem 1rem; color: var(--color-text); background: rgba(247,250,250,0.84); border: 1px solid rgba(39,49,58,0.14); border-radius: 10px; font: 500 0.94rem/1.5 var(--font-sans); transition: border-color .2s, box-shadow .2s, background .2s; }
  .form-field select { appearance: none; background-image: linear-gradient(45deg, transparent 50%, var(--color-text-muted) 50%), linear-gradient(135deg, var(--color-text-muted) 50%, transparent 50%); background-position: calc(100% - 18px) 50%, calc(100% - 13px) 50%; background-size: 5px 5px; background-repeat: no-repeat; padding-right: 2.5rem; }
  .form-field textarea { resize: vertical; min-height: 7rem; }
  .form-field input:focus, .form-field select:focus, .form-field textarea:focus { outline: none; background-color: white; border-color: var(--color-primary); box-shadow: 0 0 0 3px rgba(42,111,126,.11); }
  .form-field input::placeholder, .form-field textarea::placeholder { color: rgba(39,49,58,.42); }
  .access-form__submit { width: 100%; justify-content: center; margin-top: .45rem; }
  .access-form__submit:disabled { cursor: wait; opacity: .72; }
  .spinner { width: 15px; height: 15px; border: 2px solid rgba(255,255,255,.35); border-top-color: white; border-radius: 50%; animation: spin .75s linear infinite; }
  .form-status { padding: .9rem 1rem; text-align: center; border-radius: 10px; font-size: .88rem; color: #a12a2a; background: rgba(185,28,28,.08); border: 1px solid rgba(185,28,28,.18); }
  @keyframes spin { to { transform: rotate(360deg); } }
  
  @media (max-width: 960px) { 
    .access { grid-template-columns: 1fr; gap: 3rem; padding-top: 9rem; } 
    .access__intro { position: static; } 
    .access__aside { max-width: 34rem; } 
    
    .progress-rail { margin-top: 2rem; margin-bottom: 2rem; }
    .progress-rail__list { flex-direction: row; gap: 1rem; justify-content: space-between; max-width: 34rem; }
    .progress-rail__list::before { top: 13px; left: 10px; right: 10px; bottom: auto; width: auto; height: 2px; }
    .progress-rail__link { flex-direction: column; gap: 0.5rem; background: var(--color-page); }
  }
  
  @media (max-width: 600px) { 
    .access { width: min(100% - 1.3rem, var(--page-max)); padding-bottom: 3rem; } 
    .access__intro { padding-inline: .65rem; } 
    .access__aside { grid-template-columns: 1fr; gap: 1rem; } 
    .access__panel { padding: 1.35rem; border-radius: 22px; } 
    .access-form__row { grid-template-columns: 1fr; } 
    
    .progress-rail__list { display: none; }
    .progress-rail__mobile-status { display: block; }
  }
</style>

<script>
  interface FormResponse { error?: string; }

  let cleanupEarlyAccessForm = () => {};
  
  function initEarlyAccessForm() {
    const form = document.getElementById('early-access-form') as HTMLFormElement | null;
    const submit = document.getElementById('submit-btn') as HTMLButtonElement | null;

    if (!form || !submit || form.dataset.initialized === 'true') return;
    form.dataset.initialized = 'true';

    cleanupEarlyAccessForm();
    const controller = new AbortController();
    let observer: IntersectionObserver | undefined;
    
    // Intersection Observer for progress rail
    const steps = document.querySelectorAll('.access-form__step');
    const links = document.querySelectorAll('.progress-rail__link');
    const mobileStep = document.getElementById('mobile-step');
    
    if ('IntersectionObserver' in window && steps.length > 0) {
      const sectionObserver = new IntersectionObserver((entries) => {
        let activeId = '';
        entries.forEach(entry => {
          if (entry.isIntersecting && entry.intersectionRatio > 0.2) {
            activeId = entry.target.id;
          }
        });

        if (activeId) {
          links.forEach((link, index) => {
            const isActive = link.getAttribute('data-step') === activeId;
            link.classList.toggle('is-active', isActive);
            if (isActive) {
              link.setAttribute('aria-current', 'step');
              if (mobileStep) mobileStep.textContent = String(index + 1);
            } else {
              link.removeAttribute('aria-current');
            }
          });
        }
      }, { rootMargin: '-20% 0px -60% 0px', threshold: 0.2 });

      observer = sectionObserver;
      steps.forEach(step => sectionObserver.observe(step));
    }
    
    // Smooth scrolling for links
    links.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = (e.currentTarget as HTMLAnchorElement).getAttribute('href')?.substring(1);
        if (targetId) {
          const target = document.getElementById(targetId);
          if (target) {
            target.scrollIntoView({ behavior: 'smooth' });
          }
        }
      }, { signal: controller.signal });
    });
    
    const text = document.getElementById('btn-text');
    const icon = document.getElementById('btn-icon');
    const spinner = document.getElementById('btn-spinner');
    const status = document.getElementById('form-status');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!form.reportValidity()) return;
      submit.disabled = true;
      if (text) text.textContent = 'Submitting...';
      if (icon) icon.hidden = true;
      if (spinner) spinner.hidden = false;
      if (status) status.hidden = true;

      try {
        const response = await fetch('/api/send-email', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(Object.fromEntries(new FormData(form).entries())) });
        const result = await response.json() as FormResponse;
        if (!response.ok) throw new Error(result.error || 'We could not submit your request.');
        window.location.assign('/?early-access=received');
      } catch (error) {
        if (status) { status.textContent = error instanceof Error ? error.message : 'Something went wrong. Please try again.'; status.hidden = false; }
        submit.disabled = false;
        if (text) text.textContent = 'Submit request';
        if (icon) icon.hidden = false;
        if (spinner) spinner.hidden = true;
      }
    }, { signal: controller.signal });

    cleanupEarlyAccessForm = () => {
      controller.abort();
      observer?.disconnect();
      form.removeAttribute('data-initialized');
    };
  }
  
  initEarlyAccessForm();
  document.addEventListener('astro:page-load', initEarlyAccessForm);
  document.addEventListener('astro:before-swap', () => cleanupEarlyAccessForm());
</script>
