---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFrame from "../components/SiteFrame.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ProductCard from "../components/ProductCard.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import TrustBoundary from "../components/TrustBoundary.astro";

const products = [
  {
    title: "Password & Secrets Management",
    status: "Active Development",
    description: "Our flagship Password & Secrets Management platform is an on-premises, air-gap capable, zero-knowledge system built from the ground up with hybrid classical and post-quantum encryption. It is specifically designed for regulated, high-trust environments such as defense, financial services, healthcare, and critical enterprise infrastructure, ensuring that your organization retains absolute ownership and control over its most sensitive operational data.",
    accentClass: "product-card__accent--flagship",
  },
];
---

<BaseLayout
  title="Products - Canopryx"
  description="Explore Canopryx's focused set of cybersecurity tools, from secure vault management to future confidential programs."
>
  <SiteFrame>
    <main>
    <section class="products page-shell">
      <div class="products__header">

        <h1 class="products__title enter-after-nav" style="--enter-delay: 0.5s;">Our Products</h1>
        <p class="products__subtitle enter-after-nav" style="--enter-delay: 0.58s;">
          A focused set of security tools, with more to come.
        </p>
      </div>

      <div class="products__grid">
        {products.map((product, i) => (
          <ProductCard
            title={product.title}
            status={product.status}
            description={product.description}
            accentClass={product.accentClass}
            index={i}
          >
            <Fragment slot="icon">
              <svg class="product-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="16" r="1"/>
                <rect x="3" y="10" width="18" height="12" rx="2"/>
                <path d="M7 10V7a5 5 0 0 1 10 0v3"/>
              </svg>
            </Fragment>
          </ProductCard>
        ))}
      </div>
    </section>

    <TrustBoundary />

    </main>
  </SiteFrame>

  <SiteFooter />
  <ScrollReveal />
</BaseLayout>
