---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ProductCard from "../components/ProductCard.astro";
import ScrollReveal from "../components/ScrollReveal.astro";

const products = [
  {
    title: "Secure Vault Manager",
    status: "Flagship Focus",
    description: "A secure vault and credential-management platform built for modern teams.",
    accentClass: "product-card__accent--flagship",
  },
  {
    title: "Confidential Program // Sanitization",
    status: "Coming Soon",
    description: "A confidential security program currently in development.",
    accentClass: "product-card__accent--sanitization",
  },
  {
    title: "Confidential Program // Exposure Mapping",
    status: "Coming Soon",
    description: "Another confidential product track, to be revealed later.",
    accentClass: "product-card__accent--exposure",
  },
];
---

<BaseLayout
  title="Products — Olvara Labs"
  description="Explore Olvara Labs' focused set of cybersecurity tools — from Secure Vault Manager to future confidential programs."
>
  <SiteHeader />

  <main>
    <section class="products page-shell" style="padding-top: 9rem; padding-bottom: 4rem;">
      <div class="products__header">
        <span class="eyebrow enter-after-nav" style="--enter-delay: 0.42s;">Product Lineup</span>
        <h1 class="products__title enter-after-nav" style="--enter-delay: 0.5s;">Our Products</h1>
        <p class="products__subtitle enter-after-nav" style="--enter-delay: 0.58s;">
          A focused set of security tools, with more to come.
        </p>
      </div>

      <div class="products__grid">
        {products.map((product, i) => (
          <ProductCard
            title={product.title}
            status={product.status}
            description={product.description}
            accentClass={product.accentClass}
            index={i}
          >
            <Fragment slot="icon">
              {i === 0 && (
                <svg class="product-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="16" r="1"/>
                  <rect x="3" y="10" width="18" height="12" rx="2"/>
                  <path d="M7 10V7a5 5 0 0 1 10 0v3"/>
                </svg>
              )}
              {i === 1 && (
                <svg class="product-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"/>
                  <path d="M20 2v4"/><path d="M22 4h-4"/>
                  <circle cx="4" cy="20" r="2"/>
                </svg>
              )}
              {i === 2 && (
                <svg class="product-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M19.07 4.93A10 10 0 0 0 6.99 3.34"/>
                  <path d="M4 6h.01"/>
                  <path d="M2.29 9.62A10 10 0 1 0 21.31 8.35"/>
                  <path d="M16.24 7.76A6 6 0 1 0 8.23 16.67"/>
                  <path d="M12 18h.01"/>
                  <path d="M17.99 11.66A6 6 0 0 1 15.77 16.67"/>
                  <circle cx="12" cy="12" r="2"/>
                  <path d="m13.41 10.59 5.66-5.66"/>
                </svg>
              )}
            </Fragment>
          </ProductCard>
        ))}
      </div>
    </section>
  </main>

  <SiteFooter />
  <ScrollReveal />
</BaseLayout>
