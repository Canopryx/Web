---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFrame from "../components/SiteFrame.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout
  title="Canopryx | On-Premises Security Infrastructure"
  description="Canopryx builds air-gap capable, zero-knowledge security infrastructure for organizations that require full control over credentials, secrets, and sensitive data."
>
  <SiteFrame>
    <main>
      <Hero />
    </main>
  </SiteFrame>

  <SiteFooter noMargin={true} />

  <div class="early-access-success" id="early-access-success" hidden>
    <div class="early-access-success__backdrop" data-success-close></div>
    <section class="early-access-success__card" role="dialog" aria-modal="true" aria-labelledby="early-access-success-title" tabindex="-1">
      <button class="early-access-success__close" type="button" aria-label="Close confirmation" data-success-close>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
      </button>
      <div class="early-access-success__mark" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="m5 12 4 4L19 6"/></svg>
      </div>
      <p class="early-access-success__eyebrow">Request received</p>
      <h2 id="early-access-success-title">Thank you for raising your hand.</h2>
      <p>We’ll review your environment and get back to you if Canopryx is a strong fit.</p>
      <button class="early-access-success__button" type="button" data-success-close>Back to Canopryx</button>
    </section>
  </div>
</BaseLayout>

<style>
  .early-access-success {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: grid;
    place-items: center;
    padding: 1.25rem;
  }

  .early-access-success[hidden] { display: none; }

  .early-access-success__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 16, 20, 0.68);
    backdrop-filter: blur(10px);
    animation: success-fade 0.25s ease-out;
  }

  .early-access-success__card {
    position: relative;
    width: min(100%, 31rem);
    padding: 3.25rem 2.75rem 2.75rem;
    overflow: hidden;
    text-align: center;
    background:
      radial-gradient(circle at 15% 0%, rgba(56, 161, 105, 0.17), transparent 35%),
      #f8fbf9;
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 28px;
    box-shadow: 0 28px 90px rgba(3, 12, 16, 0.35);
    animation: success-rise 0.42s var(--ease-smooth);
  }

  .early-access-success__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: grid;
    width: 2.4rem;
    height: 2.4rem;
    place-items: center;
    color: var(--color-text-muted);
    background: rgba(39, 49, 58, 0.06);
    border: 0;
    border-radius: 50%;
    cursor: pointer;
  }

  .early-access-success__close svg { width: 1rem; fill: none; stroke: currentColor; stroke-width: 2; }

  .early-access-success__mark {
    display: grid;
    width: 4rem;
    height: 4rem;
    margin: 0 auto 1.5rem;
    place-items: center;
    color: white;
    background: linear-gradient(145deg, var(--color-primary), var(--color-primary-light));
    border-radius: 18px;
    box-shadow: 0 14px 30px rgba(42, 111, 126, 0.25);
    transform: rotate(-4deg);
  }

  .early-access-success__mark svg { width: 1.8rem; fill: none; stroke: currentColor; stroke-width: 2.4; }
  .early-access-success__eyebrow { margin-bottom: 0.75rem; font: 700 0.72rem/1 var(--font-display); letter-spacing: 0.17em; text-transform: uppercase; color: var(--color-primary); }
  .early-access-success h2 { font-size: clamp(1.8rem, 5vw, 2.45rem); line-height: 1.08; letter-spacing: -0.035em; color: var(--color-text); }
  .early-access-success p:not(.early-access-success__eyebrow) { max-width: 25rem; margin: 1rem auto 0; line-height: 1.75; color: var(--color-text-muted); }
  .early-access-success__button { margin-top: 1.8rem; padding: 0.8rem 1.4rem; font: 650 0.78rem/1 var(--font-display); letter-spacing: 0.09em; text-transform: uppercase; color: white; background: var(--color-primary); border: 0; border-radius: var(--radius-pill); cursor: pointer; }

  @keyframes success-fade { from { opacity: 0; } }
  @keyframes success-rise { from { opacity: 0; transform: translateY(22px) scale(0.97); } }

  @media (max-width: 540px) {
    .early-access-success__card { padding: 3rem 1.5rem 2rem; border-radius: 24px; }
  }
</style>

<script>
  function initEarlyAccessSuccess() {
    const modal = document.getElementById('early-access-success');
    if (!(modal instanceof HTMLElement) || modal.dataset.initialized === 'true') return;
    modal.dataset.initialized = 'true';

    const url = new URL(window.location.href);
    if (url.searchParams.get('early-access') !== 'received') return;

    url.searchParams.delete('early-access');
    window.history.replaceState({}, '', `${url.pathname}${url.search}${url.hash}`);

    const card = modal.querySelector<HTMLElement>('.early-access-success__card');
    const previousFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    const close = () => {
      modal.hidden = true;
      document.body.style.overflow = '';
      previousFocus?.focus();
    };

    modal.querySelectorAll('[data-success-close]').forEach((element) => element.addEventListener('click', close));
    modal.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') close();
    });

    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    card?.focus();
  }

  initEarlyAccessSuccess();
  document.addEventListener('astro:page-load', initEarlyAccessSuccess);
</script>
