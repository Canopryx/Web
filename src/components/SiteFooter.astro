---
interface Props {
  noMargin?: boolean;
}
const { noMargin = false } = Astro.props;
---
<footer class={`site-footer ${noMargin ? 'site-footer--no-margin' : ''}`}>
  <div class="page-shell">
    <div class="footer__inner">
      <div class="footer__brand">
        <div class="footer__brand-mark">
          <img
            src="/logo.webp"
            alt=""
            class="footer__logo"
            width="96"
            height="96"
            loading="lazy"
          />
          <div>
            <p class="footer__brand-kicker">Canopryx</p>
            <p class="footer__brand-text">On-premises security infrastructure for high-trust teams.</p>
          </div>
        </div>
        <p class="footer__brand-note">Designed for organizations that would rather own the blast radius than outsource it.</p>
      </div>

      <div class="footer__links-area">
        <div>
          <h3 class="footer__col-title">Company</h3>
          <a class="footer__link" href="/about">About</a>
          <a class="footer__link" href="/about#principles">Principles</a>
          <a class="footer__link" href="mailto:careers@canopryx.com">Careers</a>
        </div>
        <div>
          <h3 class="footer__col-title">Resources</h3>
          <a class="footer__link" href="/contact">Contact</a>
          <a class="footer__link" href="mailto:security@canopryx.com">Security</a>
        </div>
      </div>

      <div class="footer__cta-area">
        <p class="footer__cta-label">Ready to secure<br>your&nbsp;operations?</p>
        <a class="footer__cta-btn" href="/contact" id="footer-contact-btn">
          Get in Touch
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>

      </div>
    </div>
    <div class="footer__wordmark-wrap" aria-hidden="true">
      <p class="footer__wordmark" data-footer-wordmark>
        <span class="footer__wordmark-text" data-footer-wordmark-text>Canopryx</span>
      </p>
    </div>

    <div class="footer__bottom">
      <span>&copy; {new Date().getFullYear()} Canopryx. All rights reserved.</span>
      <div class="footer__bottom-links">
        <a class="footer__bottom-link" href="/privacy">Privacy Policy</a>
        <a class="footer__bottom-link" href="/terms">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  function fitFooterWordmark() {
    const wordmark = document.querySelector('[data-footer-wordmark]');
    const text = document.querySelector('[data-footer-wordmark-text]');

    if (!(wordmark instanceof HTMLElement) || !(text instanceof HTMLElement)) {
      return;
    }

    wordmark.style.setProperty('--footer-wordmark-scale', '1');

    const styles = window.getComputedStyle(wordmark);
    const horizontalGutter = parseFloat(styles.paddingLeft) + parseFloat(styles.paddingRight);
    const verticalGutter = parseFloat(styles.paddingTop) + parseFloat(styles.paddingBottom);
    const availableWidth = wordmark.clientWidth - horizontalGutter;
    const naturalWidth = text.offsetWidth;
    const naturalHeight = text.offsetHeight;

    if (!availableWidth || !naturalWidth || !naturalHeight) {
      return;
    }

    const scale = availableWidth / naturalWidth;
    wordmark.style.setProperty('--footer-wordmark-scale', String(scale));
    wordmark.style.height = `${Math.ceil((naturalHeight * scale) + verticalGutter)}px`;
  }

  fitFooterWordmark();
  document.fonts?.ready.then(fitFooterWordmark);

  const wordmark = document.querySelector('[data-footer-wordmark]');
  if (wordmark instanceof HTMLElement && 'ResizeObserver' in window) {
    new ResizeObserver(fitFooterWordmark).observe(wordmark);
  }

  window.addEventListener('resize', fitFooterWordmark, { passive: true });
  document.addEventListener('astro:page-load', fitFooterWordmark);
  document.addEventListener('astro:after-swap', fitFooterWordmark);
</script>
