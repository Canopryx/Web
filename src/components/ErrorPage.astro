---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFrame from "./SiteFrame.astro";
import SiteFooter from "./SiteFooter.astro";

interface Props {
  code: string;
  eyebrow: string;
  title: string;
  description: string;
  status: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  code,
  eyebrow,
  title,
  description,
  status,
  secondaryHref = "/contact",
  secondaryLabel = "Contact us",
} = Astro.props;
---

<BaseLayout title={`${code}: ${title} | Canopryx`} description={description} noindex={true}>
  <SiteFrame>
    <main>
      <section class="error-page page-shell">
        <div class="error-page__panel panel enter-after-nav">
          <div class="error-page__signal" aria-hidden="true">
            <span></span><span></span><span></span>
          </div>
          <p class="error-page__eyebrow">{eyebrow}</p>
          <p class="error-page__code" aria-hidden="true">{code}</p>
          <h1>{title}</h1>
          <p class="error-page__description">{description}</p>
          <div class="error-page__actions">
            <a class="btn-primary" href="/">Return home</a>
            <a class="btn-secondary" href={secondaryHref}>{secondaryLabel}</a>
          </div>
          <p class="error-page__status">
            <span aria-hidden="true"></span>
            {status}
          </p>
        </div>
      </section>
    </main>
  </SiteFrame>

  <SiteFooter noMargin={true} />
</BaseLayout>

<style>
  .error-page {
    min-height: calc(100vh - 1rem);
    display: grid;
    place-items: center;
    padding-block: 8rem 4rem;
  }

  .error-page__panel {
    position: relative;
    isolation: isolate;
    width: min(100%, 46rem);
    padding: clamp(2rem, 7vw, 4.75rem);
    overflow: hidden;
    text-align: center;
  }

  .error-page__panel::before {
    content: "";
    position: absolute;
    inset: -35% 18% auto;
    z-index: -1;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(42, 111, 126, 0.18), transparent 68%);
  }

  .error-page__signal {
    position: absolute;
    inset: 1.5rem 1.5rem auto auto;
    display: flex;
    gap: 0.35rem;
  }

  .error-page__signal span {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--color-primary-light);
    opacity: 0.35;
  }

  .error-page__signal span:nth-child(2) { opacity: 0.65; }
  .error-page__signal span:nth-child(3) { opacity: 1; }

  .error-page__eyebrow {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .error-page__code {
    margin-top: 0.35rem;
    font-family: var(--font-display);
    font-size: clamp(6rem, 20vw, 11rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.08em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(42, 111, 126, 0.24);
    background: linear-gradient(180deg, rgba(36, 77, 153, 0.12), transparent 82%);
    background-clip: text;
  }

  .error-page h1 {
    margin-top: -0.3rem;
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.045em;
    text-wrap: balance;
  }

  .error-page__description {
    max-width: 35rem;
    margin: 1.25rem auto 0;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  .error-page__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  .error-page__status {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 2.5rem;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .error-page__status span {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--color-primary-light);
    box-shadow: 0 0 0 0.3rem rgba(56, 161, 105, 0.14);
  }

  @media (max-width: 480px) {
    .error-page__actions { flex-direction: column; }
    .error-page__actions a { justify-content: center; }
  }
</style>
