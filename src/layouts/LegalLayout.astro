---
import BaseLayout from "./BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface SectionLink {
  id: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  updated: string;
  sections: SectionLink[];
}

const { title, description, updated, sections } = Astro.props;
const updatedIso = new Date(updated).toISOString().slice(0, 10);
---

<BaseLayout title={`${title} - Canopryx`} description={description}>
  <SiteHeader />

  <main class="legal-page page-shell">
    <header class="legal-hero enter-after-nav">
      <h1>{title}</h1>
      <p class="legal-hero__intro">{description}</p>
      <p class="legal-hero__meta">Last updated <time datetime={updatedIso}>{updated}</time></p>
    </header>

    <div class="legal-layout">
      <aside class="legal-nav panel" aria-label={`${title} contents`}>
        <p class="legal-nav__title">On this page</p>
        <ol>
          {sections.map(({ id, label }) => (
            <li><a href={`#${id}`} data-section-link={id}>{label}</a></li>
          ))}
        </ol>
      </aside>

      <article class="legal-document panel">
        <slot />
      </article>
    </div>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .legal-page {
    padding-block: 9rem 2rem;
  }

  .legal-hero {
    max-width: 52rem;
    margin-bottom: clamp(2.5rem, 6vw, 4.5rem);
    animation-delay: 0.45s;
  }

  .legal-nav__title {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .legal-hero h1 {
    max-width: 12ch;
    font-size: clamp(2.75rem, 7vw, 5rem);
    font-weight: 550;
    line-height: 1;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  .legal-hero__intro {
    max-width: 44rem;
    margin-top: 1.4rem;
    font-size: clamp(1rem, 2vw, 1.16rem);
    line-height: 1.75;
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  .legal-hero__meta {
    display: inline-flex;
    gap: 0.45rem;
    align-items: center;
    margin-top: 1.5rem;
    padding: 0.5rem 0.75rem;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 650;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(29, 124, 73, 0.12);
    border-radius: 999px;
  }

  .legal-hero__meta time {
    color: var(--color-text);
  }

  .legal-layout {
    display: grid;
    grid-template-columns: minmax(13.5rem, 17rem) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }

  .legal-nav {
    position: relative;
    isolation: isolate;
    padding: 1.6rem;
    overflow: hidden;
    scrollbar-width: none;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.9), rgba(247, 251, 247, 0.72));
    border: 1px solid rgba(255, 255, 255, 0.86);
    border-radius: 1.75rem;
    box-shadow:
      0 18px 44px rgba(16, 82, 51, 0.08),
      inset -1px 0 rgba(29, 124, 73, 0.08),
      inset 0 1px rgba(255, 255, 255, 0.95);
  }

  .legal-nav::-webkit-scrollbar {
    display: none;
  }

  .legal-nav::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    border-radius: inherit;
    background:
      radial-gradient(circle at 100% 10%, rgba(107, 198, 142, 0.13), transparent 30%),
      linear-gradient(to bottom, transparent 8%, rgba(29, 124, 73, 0.06) 50%, transparent 92%) right / 1px 100% no-repeat;
  }

  .legal-nav ol {
    display: grid;
    gap: 0.15rem;
    margin-top: 1rem;
    list-style: none;
    counter-reset: legal-section;
  }

  .legal-nav li {
    counter-increment: legal-section;
  }

  .legal-nav a {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: 0.4rem;
    padding: 0.48rem 0.35rem;
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--color-text-muted);
    border-radius: 0.6rem;
    transition: color 160ms ease, background-color 160ms ease, transform 160ms ease;
  }

  .legal-nav a::before {
    content: counter(legal-section, decimal-leading-zero);
    font-variant-numeric: tabular-nums;
    color: var(--color-primary);
  }

  .legal-nav a:hover,
  .legal-nav a[aria-current="location"] {
    color: var(--color-primary-dark);
    background: rgba(29, 124, 73, 0.07);
  }

  .legal-nav a:hover {
    transform: translateX(0.15rem);
  }

  .legal-document {
    position: relative;
    overflow: hidden;
    padding: clamp(1.5rem, 5vw, 4rem);
    border-radius: 1.75rem;
    box-shadow: 0 24px 70px rgba(16, 82, 51, 0.07);
  }

  .legal-document::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light), transparent 78%);
  }

  .legal-document :global(section) {
    scroll-margin-top: 7rem;
  }

  .legal-document :global(section + section) {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
  }

  .legal-document :global(h2) {
    margin-bottom: 1.15rem;
    font-size: clamp(1.45rem, 3vw, 2rem);
    font-weight: 550;
    line-height: 1.2;
    letter-spacing: -0.025em;
  }

  .legal-document :global(h3) {
    margin: 1.75rem 0 0.75rem;
    font-size: 1.1rem;
    font-weight: 650;
  }

  .legal-document :global(p),
  .legal-document :global(li) {
    max-width: 72ch;
    font-size: 0.98rem;
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .legal-document :global(p + p),
  .legal-document :global(p + ul),
  .legal-document :global(ul + p) {
    margin-top: 1rem;
  }

  .legal-document :global(ul) {
    display: grid;
    gap: 0.55rem;
    padding-left: 1.25rem;
    list-style: disc;
  }

  .legal-document :global(a) {
    color: var(--color-primary-dark);
    text-decoration: underline;
    text-decoration-color: var(--color-primary-light);
    text-underline-offset: 0.22em;
  }

  .legal-document :global(strong) {
    font-weight: 650;
    color: var(--color-text);
  }

  .legal-document :global(.legal-callout) {
    margin-block: 1.5rem;
    padding: 1rem 1.15rem;
    background: rgba(29, 124, 73, 0.07);
    border: 1px solid rgba(29, 124, 73, 0.13);
    border-left: 3px solid var(--color-primary);
    border-radius: 0.9rem;
  }

  @media (max-width: 860px) {
    .legal-layout {
      grid-template-columns: 1fr;
    }

    .legal-nav ol {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 861px) {
    .legal-nav {
      position: sticky;
      top: 7rem;
      align-self: start;
      max-height: calc(100vh - 9rem);
      overflow-x: hidden;
      overflow-y: auto;
      overscroll-behavior: contain;
    }
  }

  @media (max-width: 560px) {
    .legal-page {
      padding-top: 7.5rem;
    }

    .legal-nav ol {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  let cleanupLegalPage = () => {};

  function initLegalNavSticky() {
    cleanupLegalPage();

    const legalNav = document.querySelector<HTMLElement>('.legal-nav');
    if (!legalNav) return;

    const links = [...legalNav.querySelectorAll<HTMLAnchorElement>('[data-section-link]')];
    const sections = links
      .map((link) => document.getElementById(link.dataset.sectionLink ?? ''))
      .filter((section): section is HTMLElement => section !== null);

    const setActiveSection = (id: string) => {
      links.forEach((link) => {
        if (link.dataset.sectionLink === id) {
          link.setAttribute('aria-current', 'location');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    if (sections[0]) setActiveSection(sections[0].id);

    const sectionObserver = new IntersectionObserver((entries) => {
      const visibleSection = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];

      if (visibleSection) setActiveSection(visibleSection.target.id);
    }, { rootMargin: '-18% 0px -68% 0px', threshold: 0 });

    sections.forEach((section) => sectionObserver.observe(section));

    cleanupLegalPage = () => {
      sectionObserver.disconnect();
    };
  }

  initLegalNavSticky();
  document.addEventListener('astro:page-load', initLegalNavSticky);
</script>
